{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{tests/**,__pycache__/**,.venv/**,output/**}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/docs",
      "destination": "/api/docs"
    }
  ]
}
